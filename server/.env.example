# Database
DATABASE_URL="postgresql://user:password@localhost:5432/subrecon_pro"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# API
PORT=5000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"

# Stripe (for payments)
STRIPE_SECRET_KEY="sk_live_your_key_here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_key"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Subdomain Enumeration
MAX_CONCURRENT_SCANS=5
BRUTE_FORCE_WORDLIST_URL="https://raw.githubusercontent.com/danielmiessler/SecLists/master/Discovery/DNS/subdomains-top1million-5000.txt"
